    {
      "cell_type": "markdown",
      "source": [
        "## 4.5 Misclassification Costs and Threshold Selection"
      ],
      "metadata": {
        "id": "cyxysVDqnJNc"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Cost\n",
        "FN_cost = 3\n",
        "FP_cost = 1\n"
      ],
      "metadata": {
        "id": "6aPIKtuKfLEB"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Compute best threshold\n",
        "from sklearn.metrics import confusion_matrix\n",
        "import numpy as np\n",
        "\n",
        "probs = calibrated_rf.predict_proba(X_train_cls)[:,1]\n",
        "\n",
        "thresholds = np.linspace(0,1,100)\n",
        "costs = []\n",
        "\n",
        "for t in thresholds:\n",
        "    preds = (probs >= t).astype(int)\n",
        "    tn, fp, fn, tp = confusion_matrix(y_train_cls, preds).ravel()\n",
        "    cost = FN_cost * fn + FP_cost * fp\n",
        "    costs.append(cost)\n",
        "\n",
        "best_threshold = thresholds[np.argmin(costs)]\n",
        "best_threshold\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "iESoMgomfRzN",
        "outputId": "d943643e-9aae-4308-8f8e-a2163cefd01f"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "np.float64(0.4747474747474748)"
            ]
          },
          "metadata": {},
          "execution_count": 45
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Threshold vs cost plot\n",
        "plt.figure()\n",
        "plt.plot(thresholds, costs)\n",
        "plt.axvline(best_threshold)\n",
        "plt.xlabel(\"Threshold\")\n",
        "plt.ylabel(\"Total Cost\")\n",
        "plt.title(\"Threshold vs Cost\")\n",
        "plt.show()\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 472
        },
