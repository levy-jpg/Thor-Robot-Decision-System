    {
      "cell_type": "code",
      "source": [
        "cluster_names = {\n",
        "    0: \"Standard Efficient\",\n",
        "    1: \"High-Speed Compensation\",\n",
        "    2: \"High-Friction Failure Mode\",\n",
        "    3: \"Pre-Opened Efficient\"\n",
