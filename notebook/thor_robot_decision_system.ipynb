    {
      "cell_type": "markdown",
      "source": [
        "# 3. Task 1: Regression Modelling"
      ],
      "metadata": {
        "id": "__EA02E8cO6q"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "The goal of this task is to predict `task_duration_sec`, which is later used in the capstone system to estimate execution time and support time-aware planning and recovery."
      ],
      "metadata": {
        "id": "U4Xo4qoyc9Gz"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Imports\n",
        "# ------------------------------------------------------------\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "\n",
        "from sklearn.model_selection import train_test_split, KFold, cross_validate\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.compose import ColumnTransformer\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.ensemble import RandomForestRegressor\n",
        "\n",
        "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
        "\n",
        "import matplotlib.pyplot as plt"
      ],
      "metadata": {
        "id": "TcdriwFQaHXA"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3.1 Feature Selection and Data Split"
      ],
      "metadata": {
        "id": "kE4Tt6ordiAS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Feature selection\n",
        "# ------------------------------------------------------------\n",
        "# Leakage-aware: excluded action breakdown variables like put_actions, pickup_actions, action_count_total, etc.\n",
        "features = [\n",
        "    'path_len_m',\n",
        "    'obstacles_seen',\n",
        "    'grasp_attempts',\n",
        "    'doors_opened',\n",
        "    'avg_speed',\n",
        "    'collision_count',\n",
        "    'cupboard_open_init',\n",
        "    'clutter_level',\n",
        "    'distractors_level'\n",
        "]\n",
        "target = 'task_duration_sec'"
      ],
      "metadata": {
        "id": "pRg497P5aRER"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Confirmation check: ensuring features exist\n",
        "missing = [c for c in features + [target, 'scenario'] if c not in df.columns]\n",
        "if missing:\n",
        "    raise ValueError(f\"Missing columns in df: {missing}\")\n",
        "\n",
        "X = df[features].copy()\n",
        "y = df[target].copy()\n"
      ],
      "metadata": {
        "id": "XVjh-RIWaVBy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Train/Test split (test frozen)\n",
        "# ------------------------------------------------------------\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X, y,\n",
        "    test_size=0.20,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "# Scenario labels kept for later residual-by-scenario analysis\n",
        "scenario_train = df.loc[X_train.index, 'scenario']\n",
        "scenario_test = df.loc[X_test.index, 'scenario']"
      ],
      "metadata": {
        "id": "l9chw2r3aYKl"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3.2 Shared Preprocessing Pipeline"
      ],
      "metadata": {
        "id": "Fi5ieWlleUdA"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Preprocessing pipeline (same for all models)\n",
        "# ------------------------------------------------------------\n",
        "numeric_features = features\n",
        "\n",
        "preprocessor = ColumnTransformer(\n",
        "    transformers=[\n",
        "        (\"num\", StandardScaler(), numeric_features)\n",
        "    ],\n",
        "    remainder=\"drop\"\n",
        ")\n"
      ],
      "metadata": {
        "id": "DCgtE823agjL"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3.3 Model Comparison with Cross-Validation"
      ],
      "metadata": {
        "id": "0_A0iRIie-pZ"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Cross validation\n",
        "# ------------------------------------------------------------\n",
        "def cv_summary(cv_result: dict, name: str) -> dict:\n",
        "    # cross_validate returns negative errors for \"neg_*\" scorers\n",
        "    mae = -cv_result[\"test_neg_mean_absolute_error\"]\n",
        "    mse = -cv_result[\"test_neg_mean_squared_error\"]\n",
        "    r2  =  cv_result[\"test_r2\"]\n",
        "\n",
        "    return {\n",
        "        \"Model\": name,\n",
        "        \"MAE_mean\": mae.mean(),\n",
        "        \"MAE_std\": mae.std(ddof=1),\n",
        "        \"MSE_mean\": mse.mean(),\n",
        "        \"MSE_std\": mse.std(ddof=1),\n",
        "        \"R2_mean\": r2.mean(),\n",
        "        \"R2_std\": r2.std(ddof=1),\n",
        "    }\n",
        "\n",
        "\n",
        "cv = KFold(n_splits=5, shuffle=True, random_state=42)\n",
        "scoring = (\"neg_mean_absolute_error\", \"neg_mean_squared_error\", \"r2\")"
      ],
      "metadata": {
        "id": "ZA5iiiLpajmg"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Model A — Linear Regression (raw target)\n",
        "# ------------------------------------------------------------\n",
        "lin_pipeline = Pipeline(steps=[\n",
        "    (\"preprocessor\", preprocessor),\n",
        "    (\"model\", LinearRegression())\n",
        "])\n",
        "\n",
        "lin_cv = cross_validate(\n",
        "    lin_pipeline,\n",
        "    X_train,\n",
        "    y_train,\n",
        "    cv=cv,\n",
        "    scoring=scoring,\n",
        "    return_train_score=False\n",
        ")\n",
        "\n",
        "lin_summary = cv_summary(lin_cv, \"LinearRegression (raw y)\")"
      ],
      "metadata": {
        "id": "6Vj2hwQSanRy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Model B — Random Forest (raw target)\n",
        "# ------------------------------------------------------------\n",
        "rf_pipeline = Pipeline(steps=[\n",
        "    (\"preprocessor\", preprocessor),\n",
        "    (\"model\", RandomForestRegressor(\n",
        "        n_estimators=300,\n",
        "        random_state=42,\n",
        "        n_jobs=-1\n",
        "    ))\n",
        "])\n",
        "\n",
        "rf_cv = cross_validate(\n",
        "    rf_pipeline,\n",
        "    X_train,\n",
        "    y_train,\n",
        "    cv=cv,\n",
        "    scoring=scoring,\n",
        "    return_train_score=False\n",
        ")\n",
        "\n",
        "rf_summary = cv_summary(rf_cv, \"RandomForestRegressor (raw y)\")"
      ],
      "metadata": {
        "id": "lDCvj8lAar5q"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Model C — Linear Regression (log1p target)\n",
        "# ------------------------------------------------------------\n",
        "\n",
        "# Cross validation on log(y) metrics are in log-space.\n",
        "y_train_log = np.log1p(y_train)\n",
        "\n",
        "lin_log_cv = cross_validate(\n",
        "    lin_pipeline,\n",
        "    X_train,\n",
        "    y_train_log,\n",
        "    cv=cv,\n",
        "    scoring=scoring,\n",
        "    return_train_score=False\n",
        ")\n",
        "\n",
        "lin_log_summary = cv_summary(lin_log_cv, \"LinearRegression (log1p y) [CV in log-space]\")"
      ],
      "metadata": {
        "id": "SGcwMxjqa1dB"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Comparison table (Cross Validation)\n",
        "# ------------------------------------------------------------\n",
        "results_cv = pd.DataFrame([lin_summary, rf_summary, lin_log_summary])\n",
        "results_cv"
      ],
