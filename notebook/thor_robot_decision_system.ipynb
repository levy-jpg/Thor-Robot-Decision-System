    {
      "cell_type": "markdown",
      "source": [
        "## 5.3 Association Rule Mining"
      ],
      "metadata": {
        "id": "xG59z340jQyf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "#Deprecation warning removal\n",
        "import warnings\n",
        "warnings.filterwarnings(\"ignore\", category=DeprecationWarning)\n"
      ],
      "metadata": {
        "id": "0J3Vx762lI_q"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Association Rules\n",
        "# ------------------------------------------------------------\n",
        "df_rules = df.copy()\n",
        "\n",
        "df_rules['high_clutter'] = df_rules['clutter_level'] > df_rules['clutter_level'].median()\n",
        "df_rules['high_obstacles'] = df_rules['obstacles_seen'] > df_rules['obstacles_seen'].median()\n",
        "df_rules['high_grasp'] = df_rules['grasp_attempts'] > df_rules['grasp_attempts'].median()\n",
        "df_rules['high_collision'] = df_rules['collision_count'] > df_rules['collision_count'].median()\n",
        "df_rules['high_speed'] = df_rules['avg_speed'] > df_rules['avg_speed'].median()\n",
        "df_rules['failure'] = df_rules['success'] == 0\n"
      ],
      "metadata": {
        "id": "u6pQkcGbjTAy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# rule columns\n",
        "from mlxtend.frequent_patterns import apriori, association_rules\n",
        "\n",
        "rule_columns = [\n",
        "    'high_clutter',\n",
        "    'high_obstacles',\n",
        "    'high_grasp',\n",
        "    'high_collision',\n",
        "    'high_speed',\n",
        "    'failure'\n",
        "]\n",
        "\n",
        "df_ap = df_rules[rule_columns].astype(bool)\n"
      ],
      "metadata": {
        "id": "921hsiNJjXAg"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ------------------------------------------------------------\n",
        "# Apriori\n",
        "# ------------------------------------------------------------\n",
        "frequent = apriori(df_ap, min_support=0.1, use_colnames=True)\n",
        "rules = association_rules(frequent, metric=\"lift\", min_threshold=1.0)\n",
        "\n",
        "rules.sort_values(by=\"lift\", ascending=False).head(10)\n"
      ],
      "metadata": {
