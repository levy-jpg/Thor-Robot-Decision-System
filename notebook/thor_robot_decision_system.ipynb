        "    # still call LLM for demonstration (but ignore output)\n",
        "    if llm_gen is not None:\n",
        "        try:\n",
        "            _ = llm_gen(\"Summarise this robot decision in one sentence.\", max_new_tokens=10)\n",
        "        except:\n",
        "            pass\n",
        "\n",
        "    return explanation\n"
